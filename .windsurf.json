{
  "version": "1.0",
  "name": "Voice-to-Website - 3000 Studios",
  "description": "Autonomous Web Engineering & Monetization Engine powered by AI",

  "ai": {
    "enabled": true,
    "contextAware": true,
    "autoSuggest": true,
    "autoExecute": true,
    "fullAutomation": true,
    "codeCompletion": {
      "enabled": true,
      "autoApply": true,
      "triggerCharacters": [".", "(", "[", "{", "<", "\"", "'"],
      "languages": [
        "javascript",
        "typescript",
        "typescriptreact",
        "javascriptreact",
        "html",
        "css",
        "json"
      ]
    },
    "chatAssistant": {
      "enabled": true,
      "autoExecuteCommands": true,
      "contextFiles": ["PROJECT_PROGRESS.md", "README.md", "package.json", "ops/site/progress.json"]
    }
  },

  "project": {
    "type": "cloudflare-workers",
    "framework": "vite",
    "language": "typescript",
    "packageManager": "npm",
    "buildCommand": "npm run build",
    "devCommand": "npm run dev:all",
    "testCommand": "npm run test",
    "deployCommand": "npm run deploy",
    "autoRun": true,
    "autoDeploy": true
  },

  "paths": {
    "source": "src",
    "output": "dist",
    "public": "public",
    "tests": "src/**/*.test.{ts,tsx,js,jsx}",
    "config": "ops/site"
  },

  "exclude": {
    "search": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.wrangler/**",
      "**/Media/**",
      "**/black-vault/**",
      "**/voicetowebsite-orchestrator/node_modules/**"
    ],
    "watch": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.wrangler/**",
      "**/Media/**",
      "**/black-vault/**"
    ]
  },

  "codeStyle": {
    "indentSize": 2,
    "useTabs": false,
    "quoteStyle": "double",
    "semicolons": true,
    "trailingComma": "es5",
    "lineEnding": "lf"
  },

  "integrations": {
    "cloudflare": {
      "enabled": true,
      "accountId": "${CLOUDFLARE_ACCOUNT_ID}",
      "workersEnabled": true,
      "pagesEnabled": true,
      "autoDeploy": true
    },
    "git": {
      "enabled": true,
      "autoCommit": true,
      "autoPush": true,
      "branchProtection": false,
      "skipConfirmation": true
    }
  },

  "terminal": {
    "autoRun": {
      "enabled": true,
      "allCommands": true,
      "skipConfirmation": true,
      "allowWriteAccess": true,
      "allowSystemAccess": true,
      "allowFileOperations": true,
      "allowNetworkAccess": true,
      "allowEnvironmentAccess": true
    },
    "permissions": {
      "fullAccess": true,
      "readWrite": true,
      "systemLevel": true,
      "fileSystem": true,
      "network": true,
      "environment": true,
      "processManagement": true
    },
    "automation": {
      "autoExecuteNpmCommands": true,
      "autoExecuteGitCommands": true,
      "autoExecuteWranglerCommands": true,
      "autoExecuteSystemCommands": true,
      "autoExecutePowerShellCommands": true,
      "silentMode": true,
      "noPrompts": true,
      "autoApproveAll": true
    }
  },

  "tasks": {
    "dev": {
      "command": "npm run dev:all",
      "description": "Start development servers (Vite + Wrangler)",
      "autoRun": true,
      "autoRestart": true
    },
    "build": {
      "command": "npm run build",
      "description": "Build production bundle",
      "autoRun": true,
      "autoDeploy": true
    },
    "verify": {
      "command": "npm run verify",
      "description": "Run all verification checks",
      "autoRun": true,
      "autoFix": true
    },
    "deploy": {
      "command": "npm run deploy",
      "description": "Deploy to Cloudflare Workers",
      "autoRun": true,
      "skipConfirmation": true
    },
    "auto:run": {
      "command": "npm run auto:run",
      "description": "Start auto-run everything system",
      "autoRun": true,
      "background": true
    }
  },

  "automation": {
    "fullAccess": true,
    "autoAcceptAll": true,
    "noPrompts": true,
    "silentMode": true,
    "permissions": {
      "readWrite": true,
      "systemLevel": true,
      "fileSystem": true,
      "network": true,
      "environment": true,
      "processManagement": true,
      "registryAccess": true,
      "adminAccess": true
    }
  },

  "documentation": {
    "readme": "README.md",
    "progress": "PROJECT_PROGRESS.md",
    "workflows": ".agent/workflows"
  }
}
