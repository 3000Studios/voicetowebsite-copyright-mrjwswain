{
  "version": "1.0",
  "name": "Windsurf Full Automation Configuration",
  "description": "Automation settings for Windsurf aligned to repo verify, ship, and deploy rules",

  "terminal": {
    "autoRun": {
      "enabled": true,
      "allCommands": true,
      "skipAllConfirmation": true,
      "executeImmediately": true,
      "silentExecution": true,
      "allowWriteAccess": true,
      "allowSystemAccess": true,
      "allowFileOperations": true,
      "allowNetworkAccess": true,
      "allowEnvironmentAccess": true,
      "allowRegistryAccess": true,
      "allowAdminAccess": true
    },
    "permissions": {
      "fullAccess": true,
      "readWrite": true,
      "systemLevel": true,
      "fileSystem": true,
      "network": true,
      "environment": true,
      "processManagement": true,
      "registryAccess": true,
      "adminAccess": true,
      "userAccountControl": "bypass"
    },
    "automation": {
      "autoExecuteNpmCommands": true,
      "autoExecuteGitCommands": true,
      "autoExecuteWranglerCommands": true,
      "autoExecuteSystemCommands": true,
      "autoExecutePowerShellCommands": true,
      "autoExecuteBatchCommands": true,
      "autoExecuteShellCommands": true,
      "silentMode": true,
      "noPrompts": true,
      "autoApproveAll": true,
      "autoRetryOnFailure": true,
      "continueOnError": false
    }
  },

  "ai": {
    "fullAutomation": true,
    "autoExecute": true,
    "autoApplySuggestions": true,
    "autoFixErrors": true,
    "autoRefactorCode": true,
    "autoOptimizeCode": true,
    "autoWriteTests": true,
    "autoGenerateDocumentation": true,
    "noConfirmationRequired": true,
    "silentMode": true
  },

  "fileOperations": {
    "autoCreate": true,
    "autoDelete": true,
    "autoModify": true,
    "autoRename": true,
    "autoMove": true,
    "autoCopy": true,
    "skipConfirmation": true,
    "allowSystemFiles": true,
    "allowHiddenFiles": true,
    "allowReadOnlyFiles": true
  },

  "git": {
    "autoCommit": true,
    "autoPush": true,
    "autoPull": false,
    "autoMerge": false,
    "autoResolveConflicts": false,
    "skipConfirmation": true,
    "autoForcePush": false,
    "autoCreateBranches": false,
    "autoDeleteBranches": false
  },

  "deployment": {
    "autoDeploy": true,
    "autoBuild": true,
    "autoTest": true,
    "autoValidate": true,
    "skipConfirmation": true,
    "autoRetry": true,
    "autoRollback": false,
    "forceDeploy": false
  },

  "security": {
    "bypassAllRestrictions": false,
    "allowUnsignedScripts": true,
    "allowRemoteExecution": true,
    "allowElevatedPrivileges": true,
    "allowSystemModification": true,
    "allowNetworkAccess": true,
    "allowFilesystemAccess": true
  },

  "monitoring": {
    "autoStart": true,
    "autoRestart": true,
    "autoHeal": true,
    "autoLog": true,
    "autoReport": true,
    "silentOperation": true
  },

  "commands": {
    "npm": {
      "autoExecute": true,
      "allowProductionCommands": true,
      "allowGlobalInstalls": true,
      "allowForceOperations": true,
      "skipConfirmation": true
    },
    "git": {
      "autoExecute": true,
      "allowForcePush": false,
      "allowForceOperations": false,
      "allowRewriteHistory": false,
      "skipConfirmation": true
    },
    "wrangler": {
      "autoExecute": true,
      "allowProductionDeploy": true,
      "allowForceDeploy": true,
      "allowEnvironmentModification": true,
      "skipConfirmation": true
    },
    "system": {
      "autoExecute": true,
      "allowRegistryModification": true,
      "allowSystemConfiguration": true,
      "allowServiceManagement": true,
      "allowProcessManagement": true,
      "skipConfirmation": true
    },
    "powershell": {
      "autoExecute": true,
      "allowExecutionPolicy": true,
      "allowElevatedExecution": true,
      "allowScriptExecution": true,
      "allowModuleInstallation": true,
      "skipConfirmation": true
    }
  },

  "ui": {
    "suppressAllDialogs": true,
    "suppressAllNotifications": true,
    "suppressAllWarnings": true,
    "suppressAllErrors": true,
    "autoAcceptAll": true,
    "silentMode": true,
    "backgroundOperation": true
  },

  "permissions": {
    "fullSystemAccess": true,
    "readWriteAccess": true,
    "executeAccess": true,
    "networkAccess": true,
    "registryAccess": true,
    "serviceAccess": true,
    "processAccess": true,
    "fileSystemAccess": true,
    "environmentAccess": true,
    "adminAccess": true
  },

  "automation": {
    "enabled": true,
    "level": "maximum",
    "noRestrictions": false,
    "noPrompts": true,
    "noConfirmations": true,
    "noWarnings": true,
    "noDialogs": true,
    "silentExecution": true,
    "immediateExecution": true,
    "continueOnError": false,
    "autoRetry": true,
    "autoHeal": true
  }
}
