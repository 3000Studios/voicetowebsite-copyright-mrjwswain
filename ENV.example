# ENV.example — copy to `.env` for local development only.
# Production mapping:
# - Repo-managed safe vars live in `wrangler.toml` `[vars]`
# - Worker private values go in Cloudflare Dashboard → Worker → Settings → Variables and Secrets → Secrets
# - Dashboard non-secret toggles go in Cloudflare Dashboard → Worker → Settings → Variables and Secrets → Variables
# - Manual Wrangler auth stays local in your shell as `CLOUDFLARE_API_TOKEN` / `CLOUDFLARE_ACCOUNT_ID`

# -------------------------
# Admin & control
# -------------------------
CONTROL_PASSWORD=
ADMIN_PASSWORD_HASH=
ALLOW_ADMIN_HEADER_TOKEN=
ALLOW_INSECURE_ADMIN_COOKIE_SECRET=
ADMIN_COOKIE_SECRET=
ADMIN_ROLE=
ADMIN_ACCESS_CODE=

# -------------------------
# Orchestrator / local services
# -------------------------
ORCH_TOKEN=

# -------------------------
# GitHub / CI / Repo integration
# -------------------------
GH_TOKEN=
GH_BOT_TOKEN=
PERSONAL_ACCESS_TOKEN_API=

# -------------------------
# OpenAI / Generative models
# -------------------------
# Preferred: Cloudflare Workers AI binding via wrangler.toml ([ai] binding = "AI").
OPENAI_API=
OPENAI_API_KEY3=
OPENAI_MODEL=
VITE_GEMINIAPIKEY2=
VITE_GEMINI_MODEL=gemini-2.0-flash-exp

# -------------------------
# Payments — PayPal
# -------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_CLIENT_ID_PROD=
PAYPAL_CLIENT_SECRET_PROD=
VITE_PAYPAL_CLIENT_ID=
PAYPAL_PAYMENT_LINK_PROJECT_PLANNING_HUB=
PAYPAL_PAYMENT_LINK_WEB_FORGE=
PAYPAL_PAYMENT_LINK_AI_DRIVE=
PAYPAL_PAYMENT_LINK_GOOGLE_PROMPTS=

# -------------------------
# Payments — Stripe
# -------------------------
STRIPE_PUBLIC=
STRIPE_SECRET_KEY=
# Webhook: set in Stripe Dashboard → Developers → Webhooks (secret starts with whsec_).
# Used for POST /api/stripe/webhook signature verification and authoritative order recording.
STRIPE_WEBHOOK_SECRET=
STRIPE_ENDPOINT_SECRET=

# -------------------------
# Email & Deliverability
# -------------------------
RESEND_API_KEY=
SENDGRID_API_KEY=
DEMO_EMAIL_FROM="VoiceToWebsite <noreply@voicetowebsite.com>"

# -------------------------
# Ads & Analytics
# -------------------------
ADSENSE_PUBLISHER=
ADSENSE_SLOT=
ADSENSE_MODE=auto
ADSENSE_SLOT_TOP=
ADSENSE_SLOT_MID=
ADSENSE_SLOT_BOTTOM=
ADSENSE_MAX_SLOTS=3

# -------------------------
# Cloudflare Worker secrets (optional analytics / API-triggered deploy helpers)
# -------------------------
CLOUD_FLARE_API_TOKEN=
CF_ZONE_ID=

# -------------------------
# Live Room (WebSocket viewers/hosts)
# -------------------------
# Optional: viewer token for /api/live/ws?role=viewer (else CONTROL_PASSWORD used)
LIVE_ROOM_VIEWER_TOKEN=
# Optional: host token for role=host (else CONTROL_PASSWORD / LIVE_ROOM_ADMIN_TOKEN)
LIVE_ROOM_ADMIN_TOKEN=

# -------------------------
# Deploy hooks / misc
# -------------------------
CF_WORKERS_BUILDS_AUTO_DEPLOY=0
CF_DEPLOY_HOOK_URL=
CF_PAGES_DEPLOY_HOOK=
LICENSE_SECRET=
UNSPLASH_ACCESS_KEY=
