NODE_ENV=development
NODE_VERSION=20
PYTHONUNBUFFERED=1
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://voicetowebsite.com

# Project/runtime
AI_PROJECT_NAME=voicetowebsite
APP_NAME=voicetowebsite
AI_MODE=enabled
API_KEY=local-dev-api-key
GH_BASE_BRANCH=main

# Admin auth
ADMIN_EMAIL=mr.jwswain@gmail.com
ADMIN_PASSCODE=5555
ADMIN_API_KEY=replace-with-strong-random-string
ADMIN_SESSION_SECRET=replace-with-session-secret
JWT_SECRET=replace-with-jwt-secret
LICENSE_SECRET=replace-with-license-secret
GLOBAL_API_KEY=replace-with-global-api-key

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id

# GitHub (optional for local scripts)
GH_TOKEN=replace-with-github-token
GH_PAT=replace-with-github-pat
GH_BOT_TOKEN=replace-with-github-bot-token

# AI providers
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=replace-with-gemini-api-key
GROQ_API_KEY=replace-with-groq-api-key
OPENROUTER_API_KEY=replace-with-openrouter-api-key
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
MISTRAL_API_KEY=replace-with-mistral-api-key
TOGETHER_API_KEY=replace-with-together-api-key
JULES_API_KEY=replace-with-jules-api-key
PUBLIC_ASSISTANT_PROVIDER=ollama
OLLAMA_API_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_PROXY_SECRET=replace-with-ollama-proxy-secret
SOURCE_DOWNLOAD_TTL_MS=172800000
SOURCE_DOWNLOAD_MAX_COUNT=3

# Payments
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PUBLIC=pk_live_replace_me
STRIPE_PRICE_OPERATOR_OS=price_live_replace_me
STRIPE_MODE_OPERATOR_OS=subscription
STRIPE_PRICE_LAUNCH_SPRINT=price_live_replace_me
STRIPE_MODE_LAUNCH_SPRINT=payment
STRIPE_PAYMENT_LINK_OPERATOR_OS=replace-with-stripe-payment-link
STRIPE_PAYMENT_LINK_LAUNCH_SPRINT=replace-with-stripe-payment-link
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_ENV=live
PAYPAL_PRICE_OPERATOR_OS_USD=99.00
PAYPAL_PRICE_LAUNCH_SPRINT_USD=2500.00

# Ads/monetization
ADSENSE_CUSTOMER_ID=replace-with-adsense-customer-id
ADSENSE_PUBLISHER=replace-with-adsense-publisher-id
VITE_ADSENSE_PUBLISHER=ca-pub-replace-with-your-real-publisher-id
VITE_ENABLE_ADS=true

# Optional integrations
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret
