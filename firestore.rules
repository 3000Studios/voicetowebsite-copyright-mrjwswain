rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function ownsExisting() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ["user", "admin"];
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.commandsLimit == resource.data.commandsLimit
        && request.resource.data.commandsUsedThisCycle == resource.data.commandsUsedThisCycle
        && request.resource.data.commandPackBalance == resource.data.commandPackBalance;
      allow update, delete: if isAdmin();
    }

    match /sites/{siteId} {
      allow read: if ownsExisting() || isAdmin();
      allow create: if ownsIncoming() || isAdmin();
      allow update: if (ownsExisting() && ownsIncoming()) || isAdmin();
      allow delete: if ownsExisting() || isAdmin();
    }

    match /site_versions/{versionId} {
      allow read: if ownsExisting() || isAdmin();
      allow create: if ownsIncoming() || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if ownsExisting() || isAdmin();
      allow create: if ownsIncoming() || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /usage/{usageId} {
      allow read: if ownsExisting() || isAdmin();
      allow create: if ownsIncoming() || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /media_ledger/{entryId} {
      allow read: if ownsExisting() || isAdmin();
      allow create: if ownsIncoming() || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /generation_logs/{logId} {
      allow read: if ownsExisting() || isAdmin();
      allow create: if ownsIncoming() || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /support_messages/{messageId} {
      allow read: if ownsExisting() || isAdmin();
      allow create: if ownsIncoming() || isAdmin();
      allow update: if (ownsExisting() && ownsIncoming()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
