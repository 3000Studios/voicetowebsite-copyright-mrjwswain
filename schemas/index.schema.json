{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voicetowebsite.com/schemas/index.schema.json",
  "title": "VoiceToWebsite Schema Registry",
  "description": "Index of every project-local schema. Points editors and build tooling at canonical $ids.",
  "type": "object",
  "properties": {
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "path", "matches"],
        "properties": {
          "id": { "type": "string", "format": "uri" },
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "matches": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["schemas"],
  "additionalProperties": false
}
