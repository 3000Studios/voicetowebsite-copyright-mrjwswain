{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voicetowebsite.com/schemas/theme.schema.json",
  "title": "VoiceToWebsite Theme",
  "description": "Design theme stored at /content/pages/theme.json.",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "palette": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$" },
      "additionalProperties": {
        "type": "string",
        "pattern": "^(#(?:[0-9a-fA-F]{3}){1,2}|rgb[a]?\\(.+\\)|hsl[a]?\\(.+\\)|[a-zA-Z]+)$"
      }
    },
    "motion": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "updatedAt": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": true
}
