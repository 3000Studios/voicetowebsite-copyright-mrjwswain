{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details and token balance",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email" },
        "tokens": { "type": "number", "description": "Token balance" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "email", "tokens", "createdAt"]
    },
    "Site": {
      "title": "Generated Website",
      "description": "A website generated by the neural engine",
      "type": "object",
      "properties": {
        "html": { "type": "string", "description": "Raw HTML content" },
        "ownerId": { "type": "string", "description": "User ID of the owner" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "isDraft": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["html", "ownerId", "timestamp"]
    },
    "Story": {
      "title": "Tech Story",
      "description": "AI-generated stories for the ecosystem",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "seoKeywords": { "type": "string" },
        "videoUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "author", "timestamp", "seoTitle", "seoDescription", "seoKeywords"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/sites/{siteId}": {
      "schema": "Site",
      "description": "Collection of generated sites"
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Public technology stories"
    }
  }
}
