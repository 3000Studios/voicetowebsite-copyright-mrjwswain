{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm install",
      "problemMatcher": []
    },
    {
      "label": "npm: lint",
      "type": "shell",
      "command": "npm run lint",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "npm: test",
      "type": "shell",
      "command": "npm run test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "npm: build",
      "type": "shell",
      "command": "npm run build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: verify (lint+test+build)",
      "type": "shell",
      "command": "npm run lint && npm run test && npm run build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "deploy: pages (build+pages:deploy)",
      "type": "shell",
      "command": "npm run pages:deploy",
      "problemMatcher": []
    },
    {
      "label": "ops: init env (free-first)",
      "type": "shell",
      "command": "npm run ops -- env:init",
      "problemMatcher": []
    },
    {
      "label": "ops: help",
      "type": "shell",
      "command": "npm run ops -- help",
      "problemMatcher": []
    },
    {
      "label": "npm: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": []
    }
  ]
}
