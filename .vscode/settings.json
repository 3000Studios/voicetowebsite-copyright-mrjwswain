{
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": ["-NoLogo"]
    }
  },
  "terminal.integrated.scrollback": 50000,
  "terminal.integrated.enablePersistentSessions": true,
  "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
  "terminal.integrated.gpuAcceleration": "auto",
  "terminal.integrated.env.windows": {
    "NODE_OPTIONS": "--max-old-space-size=8192",
    "FORCE_COLOR": "1",
    "NPM_CONFIG_FUND": "false",
    "NPM_CONFIG_AUDIT": "false"
  },
  "vitest.enable": true,
  "vitest.nodeExecutable": "node",
  "vitest.commandLine": "npx vitest",
  "vitest.configFile": "vitest.config.ts",
  "vitest.rootPath": ".",
  "search.followSymlinks": false,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.inlineSuggest.enabled": true,
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true
  },
  "editor.acceptSuggestionOnEnter": "on",
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.tabCompletion": "on",
  "editor.inlayHints.enabled": "on",
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.linkedEditing": true,
  "editor.rulers": [100, 120],
  "editor.renderWhitespace": "selection",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1200,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.associations": {
    "*.css": "css",
    "*.html": "html",
    "*.js": "javascript",
    "*.mjs": "javascript",
    "*.cjs": "javascript"
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.wrangler/**": true,
    "**/Media/**": true,
    "**/black-vault/**": true,
    "**/test-results/**": true,
    "**/.turbo/**": true,
    "**/.cache/**": true,
    "**/coverage/**": true,
    "**/app Store apps to Sell/**": true,
    "**/src/webforge/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.wrangler": true,
    "**/Media": true,
    "**/black-vault": true,
    "**/test-results": true,
    "**/package-lock.json": true,
    "**/coverage": true,
    "**/app Store apps to Sell/**": true,
    "**/src/webforge/**": true
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.tsserver.maxTsServerMemory": 8192,
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents"
  },
  "typescript.suggest.autoImports": true,
  "javascript.suggest.autoImports": true,
  "eslint.format.enable": false,
  "eslint.run": "onSave",
  "eslint.alwaysShowStatus": true,
  "cSpell.enabled": true,
  "cSpell.language": "en",
  "cSpell.configFile": "cspell.json",
  "explorer.compactFolders": false,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.postCommitCommand": "none",
  "git.showPushSuccessNotification": false,
  "cursor.git.autoCommit": false,
  "git.confirmEmptyCommits": false,
  "git.confirmForcePush": false,
  "git.confirmNoVerifyCommit": false,
  "git.autofetchPeriod": 300,
  "gitlens.codeLens.enabled": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "path-intellisense.extensionOnImport": true,
  "npm.packageManager": "npm",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "window.restoreWindows": "all",
  "debug.javascript.autoAttachFilter": "smart",
  "task.allowAutomaticTasks": "on",
  "chat.commandCenter.enabled": true,
  "chat.agent.enabled": true,
  "chat.tools.terminal.autoApprove": {
    "powershell": true,
    "powershell.exe": true,
    "pwsh": true,
    "pwsh.exe": true,
    "cmd": true,
    "node": true,
    "npm": true,
    "npx": true,
    "nvm": true,
    "wrangler": true,
    "git": true,
    "npm run": true,
    "npm run deploy": true,
    "npm run verify": true,
    "npm run ship": true,
    "npm run ship:push": true,
    ".\\scripts\\cursor-session-init.ps1": true,
    "scripts\\cursor-session-init.ps1": true,
    ".\\scripts\\set-admin-env.ps1": true,
    ".\\scripts\\deploy-one-shot.ps1": true,
    "scripts\\set-admin-env.ps1": true,
    "scripts\\deploy-one-shot.ps1": true,
    "C:\\WorkSpaces\\voicetowebsite-copyright-mrjwswain\\scripts\\cursor-session-init.ps1": true,
    "C:\\WorkSpaces\\voicetowebsite-copyright-mrjwswain\\scripts\\set-admin-env.ps1": true,
    "C:\\WorkSpaces\\voicetowebsite-copyright-mrjwswain\\scripts\\deploy-one-shot.ps1": true
  },
  "terminal.integrated.confirmOnExit": "never",
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.defaultLocation": "editor",
  "terminal.integrated.shellIntegration.enabled": true
}
