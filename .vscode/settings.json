{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "files.autoSave": "onFocusChange",
  "workbench.editor.enablePreview": false,
  "workbench.startupEditor": "none",
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.gpuAcceleration": "auto",
  "terminal.integrated.minimumContrastRatio": 1.5,
  "files.maxMemoryForLargeFilesMB": 8192,
  "geminicodeassist.agentDebugMode": true,
  "geminicodeassist.agentYoloMode": true,
  "geminicodeassist.chat.changeView": "Inline suggestions",
  "geminicodeassist.enableTelemetry": false,
  "geminicodeassist.inlineSuggestions.suggestionSpeed": "Fast",
  "geminicodeassist.recitation.maxCitedLength": -1,
  "geminicodeassist.updateChannel": "Insiders",
  "geminicodeassist.inlineSuggestions.nextEditPredictions": true,
  "geminicodeassist.codeGenerationEnable": true,
  "geminicodeassist.codeCompletionEnable": true,
  "geminicodeassist.codeSuggestionEnable": true,
  "geminicodeassist.unitTestEnable": true,
  "geminicodeassist.contextualCodeEnable": true,
  "geminicodeassist.aisrc": true,

  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.suggestSelection": "first",
  "editor.suggest.showKeywords": true,
  "editor.suggest.showSnippets": true,
  "editor.suggest.showUsers": true,
  "editor.suggestOnTriggerCharacters": true,
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.parameterHints.enabled": true,
  "editor.parameterHints.cycle": true,

  "js/ts.suggest.autoImports": true,
  "js/ts.suggest.includeAutomaticOptionalChainCompletions": true,
  "js/ts.suggest.includeCompletionsForImportStatements": true,
  "js/ts.suggest.enabled": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.includePackageJsonAutoImports": "on",
  "js/ts.workspaceSymbols.scope": "allOpenProjects",

  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.suppressSuggestions": false,
  "editor.snippetSuggestions": "top",
  "editor.tabCompletion": "on",
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.foldingStrategy": "auto",
  "editor.showFoldingControls": "always",
  "editor.foldImportStatements": true,
  "editor.foldRegionMarker": true,
  "editor.unfoldOnClickAfterEndOfLine": false,
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 7,
  "editor.hover.enabled": "on",
  "editor.links": true,
  "editor.matchBrackets": "always",
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingQuotes": "always",
  "editor.autoSurround": "languageDefined",
  "editor.autoIndent": "full",
  "editor.smartIndent": true,
  "editor.detectIndentation": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.indentSize": 2,
  "editor.rulers": [80, 100, 120],
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": true,
  "editor.scrollBeyondLastLine": false,
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "smooth",
  "editor.renderWhitespace": "boundary",
  "editor.renderControlCharacters": true,
  "editor.renderLineHighlight": "all",
  "editor.renderLineHighlightOnlyWhenFocus": false,
  "editor.roundedSelection": true,
  "editor.selectionHighlight": true,
  "editor.occurrencesHighlight": "singleFile",
  "editor.semanticHighlighting.enabled": true,

  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.enableExperiments": true,
  "workbench.settings.enableNaturalLanguageSearch": true,

  "breadcrumbs.enabled": true,
  "outline.showVariables": false,
  "outline.showProperties": false,
  "outline.collapseItems": "alwaysExpand",

  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.confirmPasteNative": false,
  "explorer.autoReveal": true,
  "explorer.autoRevealExclude": {
    "**/node_modules": true
  },
  "explorer.openEditors.visible": 1,
  "explorer.openEditors.sortOrder": "editorOrder",

  "search.quickOpen.includeHistory": true,
  "search.quickOpen.historyFilterSortOrder": "recency",
  "search.searchOnType": true,
  "search.searchOnTypeDebouncePeriod": 300,
  "search.mode": "reuseEditor",
  "search.smartCase": true,
  "search.globalFindClipboard": true,

  "scm.diffDecorations": "gutter",
  "scm.diffDecorationsGutterWidth": 3,
  "scm.diffDecorationsGutterVisibility": "always",
  "scm.inputFontFamily": "default",
  "scm.inputFontSize": 13,

  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.autorefresh": true,
  "git.followTagsWhenSync": true,
  "git.showPushSuccessNotification": true,
  "git.suggestSmartCommit": true,
  "git.timeline.showUncommitted": true,
  "git.showUnpublishedCommitsButton": "always",

  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.enableVisualBell": false,
  "terminal.integrated.fastScrollSensitivity": 5,
  "terminal.integrated.mouseWheelZoom": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.showActiveTerminal": "always",

  "debug.inlineValues": "on",
  "debug.toolBarLocation": "floating",
  "debug.showBreakpointsInOverviewRuler": true,
  "debug.showInlineBreakpointCandidates": true,

  "diffEditor.renderSideBySide": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderIndicators": true,
  "diffEditor.codeLens": true,

  "editor.accessibilitySupport": "off",

  "extensions.ignoreRecommendations": false,
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": true,

  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.wrangler": true,
    "**/uploads/voicetowebsite.com/node_modules": true,
    "**/coverage": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/.cache": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/**": true,
    "**/dist/**": true,
    "**/.wrangler/**": true,
    "**/uploads/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.wrangler": true,
    "**/uploads": true
  },

  "npm.packageManager": "npm",
  "npm.scriptExplorerAction": "open",
  "npm.enableRunFromFolder": true,

  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "emmet.syntaxProfiles": {
    "javascript": "jsx",
    "typescript": "tsx"
  },

  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",

  "html.autoClosingTags": true,
  "html.autoCreateQuotes": true,
  "html.suggest.html5": true,

  "json.validate.enable": true,
  "json.schemas": [
    {
      "fileMatch": ["package.json"],
      "url": "https://json.schemastore.org/package"
    },
    {
      "fileMatch": ["tsconfig.json"],
      "url": "https://json.schemastore.org/tsconfig"
    },
    {
      "fileMatch": ["wrangler.toml"],
      "url": "https://json.schemastore.org/wrangler.json"
    }
  ],

  "markdown.preview.doubleClickToSwitchToEditor": true,
  "markdown.preview.breaks": true,
  "markdown.preview.linkify": true,
  "markdown.suggest.paths.enabled": true,

  "comments.openView": "file",
  "comments.useRelativeTime": true,

  "problems.autoReveal": true,
  "problems.decorations.enabled": true,
  "problems.sortOrder": "severity",

  "references.preferredLocation": "peek",

  "inlineChat.mode": "live",
  "inlineChat.acceptedOrDiscardedEdit": "remove",

  "accessibility.hideAccessibleView": true,

  "editor.experimental.asyncTokenization": true,
  "editor.experimental.asyncTokenizationLogging": false,
  "editor.experimental.dropIntoEditor.enabled": true,
  "editor.experimental.pasteActions.enabled": true,
  "workbench.experimental.settingsProfiles.enabled": true,

  "cSpell.words": [
    "voicetowebsite",
    "mrjwswain",
    "VITE",
    "ADSENSE",
    "VITE_ADSENSE",
    "VITE_API",
    "VITE_STRIPE",
    "STRIPE_PUBLISHABLE_KEY",
    "sendgrid",
    "gsap",
    "wrangler",
    "cloudflare",
    "stripe",
    "paypal",
    "ollama",
    "openrouter",
    "gemini",
    "openai",
    "dynamodb",
    "autofetch",
    "autorefresh",
    "smartcommit",
    "vitest",
    "trpc",
    "zod",
    "tanstack",
    "uuidv"
  ]
}
